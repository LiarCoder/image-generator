{
  "name": "@liarcoder/image-generator",
  "version": "2.0.0",
  "description": "CLI tool to generate images with a precise target file size",
  "type": "module",
  "bin": {
    "imgen": "./bin/imgen.js"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "test": "node --test test/",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "prepare": "husky"
  },
  "files": [
    "bin/",
    "src/"
  ],
  "keywords": [
    "cli",
    "image",
    "generator",
    "placeholder"
  ],
  "author": "LiarCoder",
  "homepage": "https://github.com/LiarCoder/image-generator",
  "repository": {
    "type": "git",
    "url": "https://github.com/LiarCoder/image-generator"
  },
  "bugs": {
    "url": "https://github.com/LiarCoder/image-generator/issues"
  },
  "license": "MIT",
  "dependencies": {
    "@inquirer/prompts": "^7.0.0",
    "chalk": "^5.0.0",
    "commander": "^12.0.0",
    "ora": "^8.0.0",
    "sharp": "^0.33.0"
  },
  "lint-staged": {
    "*.js": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": "prettier --write"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1"
  }
}
